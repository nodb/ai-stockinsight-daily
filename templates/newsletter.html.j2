<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>증권 리포트</title>
  </head>
  <body style="margin:0; padding:0; background-color:#f4f6f8; color:#17202a; font-family:Arial, 'Malgun Gothic', sans-serif; line-height:1.55;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f4f6f8" style="width:100%; background-color:#f4f6f8; margin:0; padding:0;">
      <tr>
        <td align="center" style="padding:28px 12px;">
          <table role="presentation" width="760" cellspacing="0" cellpadding="0" border="0" style="width:760px; max-width:760px; border-collapse:collapse;">
            <tr>
              <td bgcolor="#ffffff" style="background-color:#ffffff; border:1px solid #d9e0e7; border-radius:8px; padding:24px;">
                <h1 style="margin:0; color:#17202a; font-size:26px; line-height:1.25; font-weight:700;">증권 리포트</h1>
                <p style="margin:6px 0 0; color:#667085; font-size:13px;">{{ generated_at.strftime("%Y-%m-%d %H:%M KST") }}</p>
                <p style="margin:16px 0 0; color:#17202a; font-size:15px;">{{ headline }}</p>

                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%; border-collapse:collapse; margin-top:16px;">
                  <tr>
                    <td width="33.33%" valign="top" style="padding:0 4px 0 0;">
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f7f9fb" style="width:100%; background-color:#f7f9fb; border:1px solid #e5eaf0; border-collapse:collapse;">
                        <tr><td style="padding:10px 12px;"><p style="margin:0; color:#667085; font-size:12px;">KOSPI</p><p style="margin:3px 0 0; color:#17202a; font-size:15px; font-weight:700;">{{ macro.kospi or "N/A" }}</p></td></tr>
                      </table>
                    </td>
                    <td width="33.33%" valign="top" style="padding:0 4px;">
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f7f9fb" style="width:100%; background-color:#f7f9fb; border:1px solid #e5eaf0; border-collapse:collapse;">
                        <tr><td style="padding:10px 12px;"><p style="margin:0; color:#667085; font-size:12px;">KOSDAQ</p><p style="margin:3px 0 0; color:#17202a; font-size:15px; font-weight:700;">{{ macro.kosdaq or "N/A" }}</p></td></tr>
                      </table>
                    </td>
                    <td width="33.33%" valign="top" style="padding:0 0 0 4px;">
                      <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f7f9fb" style="width:100%; background-color:#f7f9fb; border:1px solid #e5eaf0; border-collapse:collapse;">
                        <tr><td style="padding:10px 12px;"><p style="margin:0; color:#667085; font-size:12px;">USD/KRW</p><p style="margin:3px 0 0; color:#17202a; font-size:15px; font-weight:700;">{{ macro.usd_krw or "N/A" }}</p></td></tr>
                      </table>
                    </td>
                  </tr>
                </table>

                {% if top_keywords %}
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f8fafc" style="width:100%; background-color:#f8fafc; border:1px solid #e5eaf0; border-collapse:collapse; margin-top:16px;">
                    <tr>
                      <td style="padding:12px;">
                        <p style="margin:0 0 8px; color:#344054; font-size:12px; font-weight:700;">오늘의 핵심 키워드</p>
                        {% for keyword in top_keywords[:5] %}
                          <span style="display:inline-block; color:#1557b0; background-color:#eef5ff; border:1px solid #bfdbfe; padding:4px 9px; font-size:12px; font-weight:700;">{{ keyword }}</span>
                        {% endfor %}
                      </td>
                    </tr>
                  </table>
                {% endif %}
              </td>
            </tr>

            <tr><td height="16" style="font-size:16px; line-height:16px;">&nbsp;</td></tr>

            <tr>
              <td bgcolor="#ffffff" style="background-color:#ffffff; border:1px solid #d9e0e7; border-radius:8px; padding:24px;">
                <h2 style="margin:0 0 14px; color:#17202a; font-size:18px; line-height:1.25; font-weight:700;">Top {{ top_articles|length }} Deep Dive</h2>
                {% for article in top_articles %}
                  {% set item = analysis.get(article.article_id) %}
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%; border-collapse:collapse;{% if not loop.first %} border-top:1px solid #e5eaf0; margin-top:16px;{% endif %}">
                    <tr>
                      <td style="{% if not loop.first %}padding-top:16px;{% endif %}">
                        <p style="margin:0 0 8px; color:#667085; font-size:12px;">#{{ loop.index }} | {{ article.section }} | {{ article.press }} | {{ article.published_at.strftime("%m/%d %H:%M") }}</p>
                        <h3 style="margin:0 0 8px; color:#17202a; font-size:16px; line-height:1.35; font-weight:700;">
                          <a href="{{ article.url }}" style="color:#1557b0; text-decoration:none;">{{ article.title }}</a>
                        </h3>
                        {% if item %}
                          <p style="margin:8px 0 0;">
                            <span style="display:inline-block; color:#ffffff; background-color:{{ item.market_impact|impact_color }}; padding:3px 8px; font-size:12px; font-weight:700;">시장 영향: {{ item.market_impact }}</span>
                            <span style="display:inline-block; color:{{ item.sentiment_score|sentiment_color }}; border:1px solid #cfd8e3; padding:2px 8px; font-size:12px; font-weight:700;">{{ item.sentiment_score|sentiment_score_label }}</span>
                            {% if item.risk_level == "high" %}
                              <span style="display:inline-block; color:#ffffff; background-color:#c2410c; padding:3px 8px; font-size:12px; font-weight:700;">주의 필요</span>
                            {% endif %}
                          </p>

                          <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#eef5ff" style="width:100%; background-color:#eef5ff; border-left:4px solid #1557b0; border-collapse:collapse; margin-top:10px;">
                            <tr>
                              <td style="padding:10px 12px;">
                                <p style="margin:0 0 4px; color:#1557b0; font-size:12px; font-weight:700;">핵심 요약</p>
                                <p style="margin:0; color:#17202a; font-size:14px; font-weight:700;">{{ item.summary }}</p>
                              </td>
                            </tr>
                          </table>

                          {% if item.key_terms %}
                            <p style="margin:10px 0 0;">
                              {% for term in item.key_terms %}
                                <span style="display:inline-block; color:#1557b0; background-color:#eef5ff; border:1px solid #bfdbfe; padding:3px 8px; font-size:12px; font-weight:700;">{{ term }}</span>
                              {% endfor %}
                            </p>
                          {% endif %}

                          <p style="margin:12px 0 0; color:#1557b0; font-size:12px; font-weight:700;">인사이트</p>
                          <p style="margin:4px 0 0; color:#17202a; font-size:14px;">{{ item.insight }}</p>
                          <p style="margin:10px 0 0;">
                            {% for ticker in article.tickers %}
                              <span style="display:inline-block; color:#344054; border:1px solid #cfd8e3; padding:2px 8px; font-size:12px;">{{ ticker.name }} {{ ticker.code }}</span>
                            {% endfor %}
                            {% for sector in item.beneficiary_sectors %}
                              <span style="display:inline-block; color:#344054; border:1px solid #cfd8e3; padding:2px 8px; font-size:12px;">{{ sector }}</span>
                            {% endfor %}
                          </p>
                          {% if item.risk_factors %}
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#fff7ed" style="width:100%; background-color:#fff7ed; border:1px solid #fed7aa; border-collapse:collapse; margin-top:12px;">
                              <tr>
                                <td style="padding:10px 12px;">
                                  <p style="margin:0 0 4px; color:#c2410c; font-size:12px; font-weight:700;">리스크 / 체크포인트</p>
                                  <p style="margin:0; color:#9a3412; font-size:13px;">{{ item.risk_factors|join(", ") }}</p>
                                </td>
                              </tr>
                            </table>
                          {% endif %}
                        {% endif %}
                      </td>
                    </tr>
                  </table>
                {% endfor %}
              </td>
            </tr>

            <tr><td height="16" style="font-size:16px; line-height:16px;">&nbsp;</td></tr>

            <tr>
              <td bgcolor="#ffffff" style="background-color:#ffffff; border:1px solid #d9e0e7; border-radius:8px; padding:24px;">
                <h2 style="margin:0 0 8px; color:#17202a; font-size:18px; line-height:1.25; font-weight:700;">Quick View</h2>
                {% for group in quick_groups %}
                  <p style="margin:{% if loop.first %}6px{% else %}16px{% endif %} 0 4px; color:#344054; font-size:13px; font-weight:700;">{{ group.sector }}</p>
                  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="width:100%; border-collapse:collapse;">
                    {% for article in group.articles %}
                      {% set item = analysis.get(article.article_id) %}
                      <tr>
                        <td width="52" valign="top" style="width:52px; border-top:1px solid #e5eaf0; padding:10px 8px 10px 0; color:{{ item.sentiment_score|sentiment_color if item else '#667085' }}; font-size:13px; font-weight:700;">{{ item.sentiment_score|sentiment_score_label if item else "0" }}</td>
                        <td valign="top" style="border-top:1px solid #e5eaf0; padding:10px 0; color:#17202a; font-size:14px;">
                          <a href="{{ article.url }}" style="color:#1557b0; text-decoration:none;">{{ article.title }}</a>
                          <p style="margin:4px 0 0; color:#667085; font-size:12px;">{{ article.press }} | {{ article.published_at.strftime("%m/%d %H:%M") }}</p>
                          {% if item %}<p style="margin:6px 0 0; color:#344054; font-size:13px;">{{ item.summary }}</p>{% endif %}
                        </td>
                      </tr>
                    {% endfor %}
                  </table>
                {% endfor %}
              </td>
            </tr>

            <tr><td height="16" style="font-size:16px; line-height:16px;">&nbsp;</td></tr>

            <tr>
              <td bgcolor="#ffffff" style="background-color:#ffffff; border:1px solid #d9e0e7; border-radius:8px; padding:18px 24px; color:#667085; font-size:12px;">
                본 뉴스레터는 공개 뉴스와 AI 요약을 기반으로 한 정보 제공 목적의 자료입니다. 특정 종목의 매수, 매도, 보유를 권유하지 않으며 투자 판단과 책임은 투자자 본인에게 있습니다.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
